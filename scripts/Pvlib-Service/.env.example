# ============================================================
# Pvlib-Service — environment variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# ── ThingsBoard ──────────────────────────────────────────────
TB_HOST=https://windforce.thingsnode.cc
TB_USERNAME=your-service-account@example.com
TB_PASSWORD=your-password

# ── Root assets to discover plants from ─────────────────────
# Comma-separated asset UUIDs. BFS walks each root's tree and
# collects any asset where isPlant=true AND pvlib_enabled=true.
# Use multiple roots to cover all hierarchy branches.
#
# Current roots:
#   SCADA Power Plants  : adcde870-21c6-11f1-b6ef-6183aed796a4
#   Windforce Plants    : a3cc3630-2737-11f1-b6ef-6183aed796a4
#   WindForce Rooftop   : fe969610-b608-11ef-a096-899314d17868
TB_ROOT_ASSET_IDS=adcde870-21c6-11f1-b6ef-6183aed796a4,a3cc3630-2737-11f1-b6ef-6183aed796a4,fe969610-b608-11ef-a096-899314d17868

# ── Scheduler ────────────────────────────────────────────────
# Set SCHEDULER_ENABLED=false to disable automatic cycling
# (useful when only using the HTTP API for on-demand runs).
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=1

# Read window: fetch station data from [now-LAG-WINDOW, now-LAG]
# LAG accounts for TB ingestion delay; WINDOW is the sample period.
READ_LAG_SECONDS=30
READ_WINDOW_SECONDS=90

# Max plants computed concurrently per cycle.
# At concurrency 5, 10 plants take ~15-20 s p95.
# Raise to 10 on t4g.medium if cycle time exceeds 45 s.
MAX_CONCURRENT_PLANTS=5

# ── Solcast API key (Tier-2 fallback) ────────────────────────
# Leave blank to use clear-sky (Tier 3) for plants without stations.
# Solcast is only called for plants that have solcast_resource_id set.
SOLCAST_API_KEY=

# ── Timezone ─────────────────────────────────────────────────
TZ_LOCAL=Asia/Colombo

# ── Service mode ─────────────────────────────────────────────
MODE=pvlib

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── Loss Rollup Configuration ────────────────────────────────
# Set to true to enable the daily 00:10 loss attribution rollup.
LOSS_ROLLUP_ENABLED=false
LOSS_DEFAULT_SETPOINT_KEYS=setpoint_active_power,curtailment_limit,power_limit
LOSS_MIN_VALID_SAMPLES=360
LOSS_LIFETIME_PAGE_DAYS=90
