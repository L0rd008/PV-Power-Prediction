{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "plants_master",
  "description": "Schema for scripts/shared/plants_master.yml — one entry per plant.",
  "type": "object",
  "required": ["plants"],
  "properties": {
    "plants": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Plant" }
    }
  },
  "definitions": {
    "Plant": {
      "type": "object",
      "required": [
        "asset_id", "name", "latitude", "longitude", "capacity_kwp",
        "active_power_unit", "actual_power_keys",
        "orientations", "module_template", "inverter_template",
        "pvlib_enabled"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
          "description": "ThingsBoard ASSET UUID for this plant."
        },
        "name": { "type": "string", "description": "Human-readable plant name." },
        "root_asset_id": {
          "type": "string",
          "description": "UUID of the root asset this plant belongs to (optional — used for discovery validation)."
        },
        "latitude":   { "type": "number", "minimum": -90,  "maximum": 90  },
        "longitude":  { "type": "number", "minimum": -180, "maximum": 180 },
        "altitude_m": { "type": "number", "minimum": -500, "maximum": 9000, "default": 0 },
        "timezone": {
          "type": "string",
          "description": "IANA timezone string, e.g. 'Asia/Colombo'.",
          "default": "Asia/Colombo"
        },
        "capacity_kwp": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "DC nameplate capacity in kWp."
        },
        "capacity_unit": {
          "type": "string",
          "enum": ["kW", "MW"],
          "default": "kW",
          "description": "Unit of capacity_kwp field (kW or MW)."
        },
        "active_power_unit": {
          "type": "string",
          "enum": ["kW", "W"],
          "description": "Unit of the plant's active-power telemetry ('kW' or 'W')."
        },
        "actual_power_keys": {
          "type": "string",
          "description": "CSV list of TB telemetry keys for meter power, first-match. E.g. 'EnergyMeter_active_power' or 'active_power'."
        },
        "commissioning_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO date plant was commissioned (YYYY-MM-DD)."
        },
        "tariff_rate_lkr": {
          "type": "number",
          "minimum": 0,
          "description": "Electricity feed-in tariff in LKR/kWh."
        },
        "orientations": {
          "type": "array",
          "minItems": 1,
          "description": "Array of panel sub-arrays.",
          "items": {
            "type": "object",
            "required": ["tilt", "azimuth", "module_count"],
            "properties": {
              "name":             { "type": "string" },
              "tilt":             { "type": "number", "minimum": 0, "maximum": 90 },
              "azimuth":          { "type": "number", "minimum": -180, "maximum": 360 },
              "module_count":     { "type": "integer", "minimum": 1 },
              "use_measured_poa": { "type": "boolean", "default": false }
            }
          }
        },
        "module_template": {
          "type": "string",
          "description": "Key referencing a module definition in templates/module_<name>.yml."
        },
        "inverter_template": {
          "type": "string",
          "description": "Key referencing an inverter definition in templates/inverter_<name>.yml."
        },
        "iam_template": {
          "type": "string",
          "description": "Optional key referencing an IAM definition. Defaults to Ashrae if absent."
        },
        "station": {
          "type": "object",
          "description": "Weather station configuration (Tier-1 data source).",
          "properties": {
            "weather_station_id": { "type": "string" },
            "ghi_key":            { "type": "string" },
            "poa_key":            { "type": "string" },
            "air_temp_key":       { "type": "string" },
            "wind_speed_key":     { "type": "string" },
            "freshness_minutes":  { "type": "integer", "default": 10 },
            "sanity_max_ghi_wm2": { "type": "number", "default": 1400 },
            "sanity_max_poa_wm2": { "type": "number", "default": 1500 }
          }
        },
        "solcast_resource_id": {
          "type": "string",
          "description": "Solcast site resource ID for Tier-2 forecast data (optional)."
        },
        "losses": {
          "type": "object",
          "description": "PVsyst-style loss fractions [0, 0.5].",
          "properties": {
            "soiling":        { "type": "number", "minimum": 0, "maximum": 0.5 },
            "lid":            { "type": "number", "minimum": 0, "maximum": 0.5 },
            "module_quality": { "type": "number", "minimum": -0.1, "maximum": 0.5 },
            "mismatch":       { "type": "number", "minimum": 0, "maximum": 0.5 },
            "dc_wiring":      { "type": "number", "minimum": 0, "maximum": 0.5 },
            "ac_wiring":      { "type": "number", "minimum": 0, "maximum": 0.5 },
            "far_shading":    { "type": "number", "minimum": 0, "maximum": 1.0 },
            "albedo":         { "type": "number", "minimum": 0, "maximum": 1.0 }
          }
        },
        "thermal_model": {
          "type": "string",
          "default": "open_rack_glass_glass",
          "description": "pvlib PVSystem thermal model name."
        },
        "setpoint_keys": {
          "type": "string",
          "description": "CSV of TB keys to query for active setpoint (curtailment limit). E.g. 'setpoint_active_power,curtailment_limit'."
        },
        "pvlib_enabled": {
          "type": "boolean",
          "description": "Whether pvlib processing is enabled for this plant."
        },
        "loss_attribution_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether loss attribution computation is enabled. Defaults to true."
        }
      },
      "additionalProperties": false
    }
  }
}
